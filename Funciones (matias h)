function sortProducts(arr4, field, order) {
  var sorted = arr4.slice()
  sorted.sort(function(a, b) {
    if (order == "asc") {
      if (a[field] < b[field]) return -1
      if (a[field] > b[field]) return 1
      return 0
    }
    else {
      if (a[field] > b[field]) return -1
      if (a[field] < b[field]) return 1
      return 0
    }
  })
  return sorted
}
