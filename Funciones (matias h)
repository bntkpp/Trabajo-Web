function doEverything(u, p2, action, dat, extraDat, moreData, flag99, cb) {
  var resultado;

  if (action === "login") {
    resultado = hacerLogin(u, p2);

  } else if (action === "buscarProductos") {
    resultado = buscarProductos(dat, extraDat, moreData);

  } else if (action === "addCart") {
    resultado = agregarAlCarrito(moreData, dat, extraDat);

  } else if (action === "checkout") {
    resultado = procesarCheckout(dat, extraDat, moreData, flag99, null);

  } else if (action === "aplicarCupon") {
    resultado = aplicarCupon(dat.codigo, dat.userId, dat.total);

  } else {
    resultado = { ok: false, msg: "accion no valida", data: null };
  }

  if (cb) {
    cb(resultado);
  }

  return resultado;
}

