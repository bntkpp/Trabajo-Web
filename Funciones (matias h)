// funcion principal (la que pide el profe)
export function doEverything(
  u,
  p2,
  action,
  dat,
  extraDat,
  moreData,
  flag99,
  cb
) {
  // renombro para entender mejor
  var email = u;
  var pass = p2;
  var acc = action;
  var data = dat;
  var extra = extraDat;
  var more = moreData;
  var opts = flag99;
  var callback = cb;

  // dependiendo de la accion llamo a una u otra funcion
  if (acc == 'login') {
    buscarUsuario(email, pass, callback);
  } else if (acc == 'buscarProductos') {
    buscarProductos(
      dbProducts,
      data,
      data,
      extra,
      callback,
      more ? more.min : 0,
      more ? more.max : 999999999
    );
  } else if (acc == 'addCart') {
    // data: prodId, extra: cantidad, more: userId
    agregarAlCarrito(null, data, extra, more, callback);
  } else if (acc == 'checkout') {
    procesarPago(data, extra, more, opts, callback);
  } else if (acc == 'getStats') {
    obtenerEstadisticas(callback);
  } else if (acc == 'aplicarCupon') {
    // data: { codigo, userId, total }
    aplicarCupon(data.codigo, data.userId, data.total, callback);
  } else if (acc == 'agregarWishlist') {
    agregarAWishlist(data.userId, data.prodId, callback);
  } else if (acc == 'quitarWishlist') {
    quitarDeWishlist(data.userId, data.prodId, callback);
  } else if (acc == 'obtenerWishlist') {
    obtenerWishlist(data.userId, callback);
  } else if (acc == 'agregarReview') {
    agregarReview(
      data.prodId,
      data.userId,
      data.rating,
      data.comentario,
      callback
    );
  } else if (acc == 'obtenerReviews') {
    obtenerReviews(data.prodId, callback);
  } else if (acc == 'likeReview') {
    darLikeReview(data.prodId, data.reviewId, callback);
  } else {
    callback({ ok: false, msg: 'accion no reconocida', data: null });
  }
}
