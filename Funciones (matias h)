// wishlist (esto lo agregue yo porque me parecio util)
export function agregarAWishlist(userId, prodId, cb) {
  var foundUser = null;
  for (var i = 0; i < dbUsers.length; i++) {
    if (dbUsers[i].id == userId) {
      foundUser = dbUsers[i];
      break;
    }
  }

  if (foundUser == null) {
    cb({ ok: false, msg: 'usuario no encontrado', data: null });
    return;
  }

  if (!foundUser.wishlist) {
    foundUser.wishlist = [];
  }

  // reviso si ya esta
  for (var i = 0; i < foundUser.wishlist.length; i++) {
    if (foundUser.wishlist[i] == prodId) {
      cb({
        ok: false,
        msg: 'producto ya en wishlist',
        data: foundUser.wishlist,
      });
      return;
    }
  }

  foundUser.wishlist.push(prodId);
  cb({ ok: true, msg: 'agregado a wishlist', data: foundUser.wishlist });
  return;
}

export function quitarDeWishlist(userId, prodId, cb) {
  var foundUser = null;
  for (var i = 0; i < dbUsers.length; i++) {
    if (dbUsers[i].id == userId) {
      foundUser = dbUsers[i];
      break;
    }
  }

  if (foundUser == null) {
    cb({ ok: false, msg: 'usuario no encontrado', data: null });
    return;
  }

  if (!foundUser.wishlist) {
    foundUser.wishlist = [];
  }

  var idx = -1;
  for (var i = 0; i < foundUser.wishlist.length; i++) {
    if (foundUser.wishlist[i] == prodId) {
      idx = i;
      break;
    }
  }

  if (idx == -1) {
    cb({ ok: false, msg: 'producto no en wishlist', data: foundUser.wishlist });
    return;
  }

  foundUser.wishlist.splice(idx, 1);
  cb({ ok: true, msg: 'removido de wishlist', data: foundUser.wishlist });
  return;
}

export function obtenerWishlist(userId, cb) {
  var foundUser = null;
  for (var i = 0; i < dbUsers.length; i++) {
    if (dbUsers[i].id == userId) {
      foundUser = dbUsers[i];
      break;
    }
  }

  if (foundUser == null) {
    cb({ ok: false, msg: 'usuario no encontrado', data: null });
    return;
  }

  cb({ ok: true, msg: 'ok', data: foundUser.wishlist || [] });
  return;
}
