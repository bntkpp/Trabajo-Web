function aplicarCupon(codigo, userId, totalCarrito) {
  var cupon = null;

  for (var i = 0; i < cupones.length; i++) {
    if (cupones[i].codigo == codigo) {
      cupon = cupones[i];
      break;
    }
  }

  if (cupon == null) {
    return { ok: false, msg: "cupon no existe", data: { descuento: 0 } };
  }

  if (!cupon.activo) {
    return { ok: false, msg: "cupon inactivo", data: { descuento: 0 } };
  }

  var hoy = new Date();
  var exp = new Date(cupon.expira);

  if (hoy > exp) {
    return { ok: false, msg: "cupon expirado", data: { descuento: 0 } };
  }

  if (cupon.usos >= cupon.maxUsos) {
    return { ok: false, msg: "cupon agotado", data: { descuento: 0 } };
  }

  if (totalCarrito < cupon.minCompra) {
    return { ok: false, msg: "no cumple minimo", data: { descuento: 0 } };
  }

  var descuento = 0;

  if (cupon.tipo == "porcentaje") {
    descuento = (totalCarrito * cupon.valor) / 100;
  } else {
    descuento = cupon.valor;
  }

  if (descuento > totalCarrito) {
    descuento = totalCarrito;
  }

  cupon.usos++;

  return {
    ok: true,
    msg: "aplicado",
    data: { descuento: descuento }
  };
}
